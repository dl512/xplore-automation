# LLM: Vercel AI Gateway (preferred) or OpenRouter / OpenAI-compatible
AI_GATEWAY_API_KEY=
# AI_GATEWAY_BASE_URL=https://ai-gateway.vercel.sh/v1

# If not using AI_GATEWAY_API_KEY:
# OPENAI_API_KEY=
# BASE_URL=

# Optional model lists (OpenAI-style ids, e.g. openai/gpt-4.1-nano)
# LLM_PRIMARY_MODELS=openai/gpt-4.1-nano,openai/gpt-4o-mini
# LLM_FALLBACK_MODEL=google/gemma-2-9b-it

# Google Sheets + GCS (path to service account JSON on the VM — do not commit the file)
GOOGLE_SHEET_ID=
GOOGLE_SERVICE_ACCOUNT_JSON=/path/to/your-service-account.json
# Alternative name also supported:
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/your-service-account.json

# Optional debug
# EXTRACTION_DEBUG=1
